{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "mode", "scene_id", "room_proxies", "camera_candidates", "semantic_objects", "semantic_object_count", "room_surface_semantic_count"],
  "properties": {
    "mode": {"const": "clean_reconstruction"},
    "semantic_object_count": {"const": 20},
    "room_surface_semantic_count": {"const": 0},
    "room_proxies": {"type": "array", "minItems": 3, "maxItems": 3},
    "camera_candidates": {"type": "array", "minItems": 2},
    "semantic_objects": {
      "type": "array", "minItems": 20, "maxItems": 20,
      "items": {
        "type": "object",
        "required": ["object_id", "semantic_label", "primitive_type", "transform", "support_target", "confidence_classification", "final_pose_confidence", "normal_frame", "validation_metrics", "ambiguity", "orientation_method"],
        "properties": {
          "object_id": {"type": "string", "pattern": "^[0-9a-f]{32}$"},
          "primitive_type": {"const": "cube"},
          "orientation_method": {"const": "normal_first_v3_universal"},
          "confidence_classification": {"enum": ["automatic_high_confidence", "automatic_with_ambiguity", "user_review_recommended", "yaw_unobservable", "insufficient_geometry"]},
          "final_pose_confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "transform": {
            "type": "object", "required": ["center", "dimensions", "rotation_matrix", "quaternion_wxyz"],
            "properties": {
              "center": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"type": "number"}},
              "dimensions": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"type": "number", "exclusiveMinimum": 0}},
              "quaternion_wxyz": {"type": "array", "minItems": 4, "maxItems": 4, "items": {"type": "number"}}
            }
          }
        }
      }
    }
  }
}
