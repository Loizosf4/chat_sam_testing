{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "manifest.schema.json",
  "title": "MoGe scene fixture manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["scene_id", "image", "objects"],
  "properties": {
    "scene_id": { "type": "string", "minLength": 1 },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["filename", "width", "height", "source_path", "sha256"],
      "properties": {
        "filename": { "type": "string", "minLength": 1 },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "source_path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "objects": {
      "type": "array",
      "minItems": 3,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["object_id", "semantic_label", "mask_filename", "source_export_path", "mask_revision", "sha256", "selection_role"],
        "properties": {
          "object_id": { "type": "string", "minLength": 1 },
          "semantic_label": { "type": "string", "minLength": 1 },
          "mask_filename": { "type": "string", "pattern": "(?i)\\.png$" },
          "source_export_path": { "type": "string", "minLength": 1 },
          "mask_revision": { "type": ["string", "integer", "null"] },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "selection_role": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
        }
      }
    }
  }
}
