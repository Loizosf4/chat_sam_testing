          "items": {
            "items": {
              "type": "number"
            },
            "type": "array"
          },
          "maxItems": 4,
          "minItems": 4,
          "title": "Canonical To Camera Transform",
          "type": "array"
        },
        "fit_confidence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Fit Confidence",
          "type": "number"
        },
        "orthographic": {
          "anyOf": [
            {
              "$ref": "#/$defs/OrthographicParameters"
            },
            {
              "type": "null"
            }
          ]
        },
        "perspective": {
          "anyOf": [
            {
              "$ref": "#/$defs/PerspectiveParameters"
            },
            {
              "type": "null"
            }
          ]
        },
        "requires_user_review": {
          "title": "Requires User Review",
          "type": "boolean"
        },
        "source_evidence": {
          "items": {
            "type": "string"
          },
          "title": "Source Evidence",
          "type": "array"
        },
        "warnings": {
          "items": {
            "type": "string"
          },
          "title": "Warnings",
          "type": "array"
        }
      },
      "required": [
        "camera_id",
        "camera_type",
        "camera_to_canonical_transform",
        "canonical_to_camera_transform",
        "perspective",
        "orthographic",
        "fit_confidence",
        "source_evidence",
        "warnings",
        "requires_user_review"
